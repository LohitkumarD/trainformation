rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Train formations — public read; only approved staff/admin can write
    match /trains/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ['staff', 'admin'];
    }

    // Train timetable — public read; only GitHub Actions / admin can write
    match /timetable/{trainNo} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles — own doc + admin
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Any authenticated user can create their own profile (for registration)
      allow create: if request.auth != null && request.auth.uid == userId;
      // Users update their own profile; admins update any (role changes, approval)
      allow update: if request.auth != null
        && (request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      // Per-user saved/favourited trains
      match /myTrains/{docId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }

    // Stations — public read; only admins manage the list
    match /stations/{code} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // FCM device tokens — registration is open to guests (push signup happens
    // before sign-in); only admins can read the list back (admin panel counts).
    match /fcm_tokens/{deviceId} {
      allow write: if true;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /admin_fcm_tokens/{deviceId} {
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Notification log — written server-side only (push.js, via a service
    // account, bypasses these rules). Admin panel reads it; any client
    // (including guests) may bump openCount when a notification is tapped.
    match /notification_log/{id} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if true;
    }
  }
}
