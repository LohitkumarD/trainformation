rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Train formations — public read; only approved staff/admin can write
    match /trains/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ['staff', 'admin'];
    }

    // Train timetable — public read; only GitHub Actions / admin can write
    match /timetable/{trainNo} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles — own doc + admin
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Any authenticated user can create their own profile (for registration)
      allow create: if request.auth != null && request.auth.uid == userId;
      // Users update their own profile; admins update any (role changes, approval)
      allow update: if request.auth != null
        && (request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');

      // Per-user saved/favourited trains
      match /myTrains/{docId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }

    // Stations — public read; only admins manage the list
    match /stations/{code} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // FCM device tokens — registration is open to guests (push signup happens
    // before sign-in); only admins can read the list back (admin panel counts).
    match /fcm_tokens/{deviceId} {
      allow write: if true;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /admin_fcm_tokens/{deviceId} {
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Notification log — written server-side only (push.js, via a service
    // account, bypasses these rules). Admin panel reads it; any client
    // (including guests) may bump openCount when a notification is tapped.
    match /notification_log/{id} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if true;
    }

    // Usage analytics — fire-and-forget activity log (app_open, search,
    // favourite_added, confirm_today, confirm_verified, share_image,
    // edit_blocked, login_prompt_shown, login_succeeded, login_failed,
    // feedback_submitted). Admin's own actions are excluded client-side
    // so their testing doesn't skew the insights.
    // Write is open since some events (app_open, search) can fire before
    // sign-in; only admins read it back for the usage dashboard.
    match /usage_logs/{id} {
      allow create: if true;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User feedback — missing trains, feature requests, bug reports, general
    // feedback. Any signed-in user (not necessarily approved staff) can
    // submit; only admins read/triage it.
    match /feedback/{id} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Crowdsourced position requests — "does anyone know today's formation
    // for this train?" Doc ID is the train number, so there's at most one
    // open request per train at a time. Read is public so the "help needed"
    // banner works for everyone; only signed-in users can ask (create) or
    // resolve (update, done automatically when someone saves that train's
    // position for today).
    match /position_requests/{trainNo} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    // Missing-train requests — auto-created when someone searches a train
    // number that isn't in the app at all yet. Open to guests on both create
    // and update (a searching passenger is often not signed in, and the only
    // "update" is a harmless searchCount bump or the auto-resolve when
    // someone adds the train) — same trust level as usage_logs/fcm_tokens.
    match /train_requests/{trainNo} {
      allow read: if true;
      allow write: if true;
    }

    // "Enable notifications" in-app reminder — a single admin-editable
    // message (doc ID "active") shown to anyone who opened the app but
    // never enabled push, since a real push can't reach them. Public read
    // so guests see it too; only admins can set it.
    match /push_reminders/{id} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
